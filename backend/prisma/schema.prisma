generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  PAYMENT
  ACCOUNT
  TECHNICAL
  SHIPPING
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SenderType {
  USER
  AGENT
  AI
}


model User {
  id Int @id @default(autoincrement())

  email String  @unique
  name  String?
  password String

  tickets Ticket[]

  refreshToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Ticket {
  id String @id @default(uuid())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  title       String
  description String

  messages TicketMessage[]

  category       Category?
  priority       Priority?
  suggestedReply String?

  status Status? @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketMessage {
  id        String     @id @default(uuid())
  ticketId  String
  ticket    Ticket     @relation(fields: [ticketId], references: [id])
  sender    SenderType
  message   String
  createdAt DateTime   @default(now())
}
